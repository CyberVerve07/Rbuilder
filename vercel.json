{
  "version": 2,
  "name": "rbuilder",
  "builds": [
    {
      "src": "frontend/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/css/**",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/js/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/.*",
      "dest": "/frontend/index.html"
    }
  ]
}
